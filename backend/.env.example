DB_DSN=host=localhost port=5432 user=postgres password=123 dbname=obrascerca_v2
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:5173,http://localhost:3000
APP_ENV=local

# Capa IA — usada por /api/obras/{id}/explicacion
# Provider permitidos: stub | minimax | anthropic
LLM_PROVIDER=stub

MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2.7

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# User-Agent para scraping (gob.pe responde 418 al UA por defecto de requests)
HTTP_UA=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/125.0.0.0 Safari/537.36
