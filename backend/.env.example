DB_DSN=host=localhost port=5432 user=postgres password=123 dbname=obrascerca
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:5173,http://localhost:3000
APP_ENV=local

# Capa IA — usada por /api/obras/{id}/explicacion (genera lenguaje ciudadano)
# Provider permitidos: stub | minimax | anthropic
LLM_PROVIDER=stub

# MiniMax (compatible Anthropic SDK)
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2.7

# Anthropic Claude (fallback)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
